# macOS
.DS_Store
._*
.AppleDouble
.LSOverride

# Editor / IDE caches (keep .cursor/ — it carries our commands and skills)
.idea/
.vscode/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.local

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
build/
.next/
coverage/

# Logs
*.log

# OpenSpec — DO NOT ignore openspec/ itself; it's the source of truth.
# Only ignore local CLI scratch if openspec writes any:
openspec/.cache/

# Superpowers — these defaults are NOT used by this template
# (we route brainstorming/writing-plans output into openspec/changes/<name>/),
# but ignore them anyway in case a stray invocation creates them.
docs/superpowers/specs/
docs/superpowers/plans/
